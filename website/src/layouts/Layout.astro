---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
}

const {
  title,
  description = "Instantly upload macOS screenshots to S3 and copy the link to your clipboard. A tiny, open-source macOS menu bar app.",
  ogImage = "/og-image.png",
  ogType = "website",
  canonicalUrl,
} = Astro.props;

const siteUrl = "https://www.aitwitterfilter.xyz";
const fullOgImage = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;
const canonical = canonicalUrl || siteUrl;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Griffin Cockfoster" />
    <meta name="theme-color" content="#06060f" />

    <!-- OpenGraph / Facebook / LinkedIn -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Screenshot S3 — macOS menu bar app for instant screenshot uploads to S3" />
    <meta property="og:site_name" content="Screenshot S3" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />
    <meta name="twitter:image:alt" content="Screenshot S3 — macOS menu bar app for instant screenshot uploads to S3" />
    <meta name="twitter:creator" content="@gcockfoster" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Screenshot S3",
      "operatingSystem": "macOS",
      "applicationCategory": "UtilitiesApplication",
      "description": description,
      "url": siteUrl,
      "image": fullOgImage,
      "author": {
        "@type": "Person",
        "name": "Griffin Cockfoster",
        "url": "https://github.com/griffincockfoster"
      },
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "downloadUrl": "https://screenshots3-downloads.s3.amazonaws.com/S3Screenshot-1.0.dmg",
      "softwareVersion": "1.0",
      "isAccessibleForFree": true
    })} />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg-dark: #06060f;
    --bg-mid: #0d0d24;
    --bg-light: #151535;
    --primary-start: #667eea;
    --primary-end: #764ba2;
    --success: #34d399;
    --text: #ffffff;
    --text-muted: rgba(255, 255, 255, 0.5);
    --text-dim: rgba(255, 255, 255, 0.3);
    --glass-bg: rgba(255, 255, 255, 0.05);
    --glass-border: rgba(255, 255, 255, 0.08);
    --glass-bg-hover: rgba(255, 255, 255, 0.08);
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: var(--bg-dark);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
    background: linear-gradient(180deg, var(--bg-dark) 0%, var(--bg-mid) 30%, var(--bg-light) 50%, var(--bg-mid) 70%, var(--bg-dark) 100%);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .glass {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .glass:hover {
    background: var(--glass-bg-hover);
    border-color: rgba(255, 255, 255, 0.12);
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 12px;
    color: white;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.25s ease;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(102, 126, 234, 0.3);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(102, 126, 234, 0.5);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    color: var(--text-muted);
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.25s ease;
    text-decoration: none;
  }

  .btn-secondary:hover {
    background: var(--glass-bg-hover);
    border-color: rgba(255, 255, 255, 0.15);
    color: white;
    transform: translateY(-2px);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }
</style>
