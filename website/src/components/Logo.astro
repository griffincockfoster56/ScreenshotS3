---
// Inline SVG replicating the LogoView bucket-person icon
---

<div class="logo-wrapper">
  <div class="logo-glow"></div>
  <svg viewBox="0 0 100 100" width="120" height="120" xmlns="http://www.w3.org/2000/svg" class="logo-svg">
    <defs>
      <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#667eea" />
        <stop offset="100%" stop-color="#764ba2" />
      </linearGradient>
      <clipPath id="squircle">
        <rect x="4" y="4" width="92" height="92" rx="22" ry="22" />
      </clipPath>
    </defs>

    <!-- Background rounded rect -->
    <rect x="4" y="4" width="92" height="92" rx="22" ry="22" fill="url(#bgGrad)" />
    <rect x="4" y="4" width="92" height="92" rx="22" ry="22" fill="none" stroke="rgba(255,255,255,0.25)" stroke-width="0.8" />

    <!-- Bucket handle arc -->
    <path d="M 37 46 A 13 13 0 0 1 63 46" fill="none" stroke="rgba(255,255,255,0.7)" stroke-width="2.8" stroke-linecap="round" />

    <!-- Person silhouette (head + shoulders) -->
    <circle cx="50" cy="38" r="6.5" fill="white" />
    <path d="M 39 53 Q 39 44 50 44 Q 61 44 61 53" fill="white" />

    <!-- Bucket body trapezoid -->
    <path d="M 32 52 L 68 52 L 65 73 Q 50 77 35 73 Z" fill="rgba(255,255,255,0.2)" />

    <!-- Bucket rim capsule -->
    <rect x="29" y="50" width="42" height="5" rx="2.5" ry="2.5" fill="rgba(255,255,255,0.45)" />

    <!-- Upload badge -->
    <circle cx="72" cy="30" r="12" fill="#34d399" />
    <circle cx="72" cy="30" r="13.5" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="1.5" />
    <!-- Arrow up -->
    <path d="M 72 35 L 72 26 M 68 30 L 72 25 L 76 30" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
</div>

<style>
  .logo-wrapper {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .logo-glow {
    position: absolute;
    width: 120px;
    height: 120px;
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 28px;
    filter: blur(28px);
    opacity: 0.5;
    animation: glowPulse 3s ease-in-out infinite alternate;
  }

  .logo-svg {
    position: relative;
    z-index: 1;
    filter: drop-shadow(0 4px 20px rgba(102, 126, 234, 0.3));
  }

  @keyframes glowPulse {
    0% {
      opacity: 0.4;
      filter: blur(24px);
    }
    100% {
      opacity: 0.65;
      filter: blur(32px);
    }
  }
</style>
